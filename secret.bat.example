@echo off
REM Copy this file to "secret.bat" (same folder) and fill in your values.
REM secret.bat is git-ignored, so it will NOT be committed.

REM --- Anthropic API key (required) ---
REM From https://console.anthropic.com/settings/keys  (starts with sk-ant-api03-).
REM A Claude Code / .credentials.json OAuth token (sk-ant-oat01-) will NOT work.
REM Quote the WHOLE assignment, not just the value.
set "ANTHROPIC_API_KEY=sk-ant-api03-REPLACE-ME"

REM --- Email sending (only needed to send for real; --dry-run needs none) ---
REM
REM Option A: Hotmail / Outlook.com over SMTP.
REM   NOTE: Microsoft is disabling basic SMTP auth for personal accounts; if
REM   login fails, enable 2FA + an app password, or use Option B.
REM set "SMTP_HOST=smtp-mail.outlook.com"
REM set "SMTP_PORT=587"
REM set "SMTP_USER=mvanormondt@hotmail.com"
REM set "SMTP_PASS=your-password-or-app-password"
REM set "EMAIL_FROM=mvanormondt@hotmail.com"
REM
REM Option B (RECOMMENDED): Resend over HTTPS. Works from corporate networks
REM   and GitHub Actions, where SMTP is blocked. Sign up at resend.com, create
REM   an API key, and set it here. For a first test you can send FROM
REM   onboarding@resend.dev TO the email you signed up with; to send from your
REM   own address, verify a domain in Resend and set EMAIL_FROM to it.
REM   If RESEND_API_KEY is set, it is used instead of SMTP.
REM set "RESEND_API_KEY=re_..."
REM set "EMAIL_FROM=onboarding@resend.dev"
